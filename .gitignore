# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime data ──────────────────────────────────────────────────────────────
data/uploads/*
data/index/*
data/conversation.json

# Keep empty directory markers so git tracks the folders
!data/uploads/.gitkeep
!data/index/.gitkeep

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key

# ── IDE / OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
.DS_Store
Thumbs.db
desktop.ini

# ── HuggingFace model cache (can be hundreds of MB) ──────────────────────────
.cache/
hf_cache/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

