# ─────────────────────────────────────────────────────────────────────────────
# Cortex — Environment Variables
#
# Copy this file to .env and fill in the required values before starting.
#   cp .env.example .env
#
# Lines starting with # are comments. Uncomment a line to override its default.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Groq API key — get a free key at https://console.groq.com
GROQ_API_KEY=gsk_your_key_here


# ── Flask ─────────────────────────────────────────────────────────────────────

# Secret key used for Flask session signing.
# IMPORTANT: change this to a long random string in production.
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Host and port the app listens on inside the container / process.
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000

# Set to true only for local development — never in production.
# FLASK_DEBUG=false


# ── LLM model (Groq) ─────────────────────────────────────────────────────────

# Groq model used for chat generation.
# Available: llama-3.1-8b-instant | llama-3.3-70b-versatile | mixtral-8x7b-32768
# GROQ_MODEL=llama-3.1-8b-instant


# ── Embeddings (Ollama — local) ───────────────────────────────────────────────

# Ollama model used for document embeddings.
# Pull once before first use: ollama pull mxbai-embed-large
# EMBED_MODEL=mxbai-embed-large

# Ollama server URL. In Docker Compose this is automatically set to the
# sidecar service. Override here only when running Ollama on a different host.
# OLLAMA_HOST=http://ollama:11434


# ── RAG / retrieval ───────────────────────────────────────────────────────────

# Number of characters per text chunk when indexing documents.
# CHUNK_SIZE=800

# Character overlap between consecutive chunks.
# CHUNK_OVERLAP=100

# Number of chunks retrieved per query.
# TOP_K=5

# L2 distance threshold — chunks with distance > threshold are ignored.
# 0.0 disables the threshold (all chunks passed to the LLM).
# SIMILARITY_THRESHOLD=0.0


# ── ChromaDB vector store ─────────────────────────────────────────────────────

# Name of the Chroma collection.
# CHROMA_COLLECTION_NAME=cortex

# Distance metric used by the HNSW index: l2 | cosine | ip
# l2 matches the behaviour of the old FAISS index.
# CHROMA_DISTANCE_METRIC=l2

# Absolute path to the Chroma persist directory.
# Unset = data/index/chroma/ (relative to the project root).
# CHROMA_PERSIST_DIR=


# ── File uploads ─────────────────────────────────────────────────────────────

# Maximum upload size in megabytes.
# MAX_UPLOAD_MB=64


# ── Gunicorn (production server) ─────────────────────────────────────────────

# Number of worker processes. Default: max(2, CPU count).
# GUNICORN_WORKERS=2

# Threads per worker.
# GUNICORN_THREADS=2

# Worker silent timeout in seconds. Increase if embedding large documents.
# GUNICORN_TIMEOUT=120

# Graceful shutdown timeout.
# GUNICORN_GRACEFUL_TIMEOUT=30

# Log level: debug | info | warning | error | critical
# GUNICORN_LOG_LEVEL=info

# Restart a worker after this many requests (prevents slow memory leaks).
# GUNICORN_MAX_REQUESTS=1000
